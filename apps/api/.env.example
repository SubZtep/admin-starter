PORT=3001
CORS_ORIGIN=http://localhost:3000

# Optional: set base domain when apps live on subdomains (e.g. ondis.co)
CROSS_PARENT_DOMAIN=

DATABASE_URL=postgresql://testuser:testpass@localhost:5433/test
BETTER_AUTH_URL=http://localhost:3001

EMAIL_FROM="Admin Starter <noreply@example.com>"

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# Secrets — keep ONLY in .env (or host env in prod). Never commit real values.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Generate: bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('hex'))"
JWT_SECRET=
