{
  "name": "@kaja/cli",
  "version": "0.0.18",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run cli.ts",
    "build": "bun build ./cli.ts --compile --minify --sourcemap --bytecode --outfile kaja",
    "build:release": "bun build ./cli.ts --compile --minify --sourcemap --bytecode --outfile kaja --env=API_*"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@kaja/schemas": "workspace:*",
    "@kaja/shared": "workspace:*",
    "better-auth": "^1.6.9",
    "clipboardy": "^5.3.1",
    "env-paths": "^4.0.0",
    "ollama": "^0.6.3",
    "open": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2"
  }
}
