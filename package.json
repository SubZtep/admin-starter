{
  "name": "admin-starter",
  "description": "monorepo",
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "dev": "bun run --filter '!@app/cli' dev",
    "dev:api": "bun run --filter @app/api dev",
    "dev:web": "bun run --filter @app/web dev",
    "dev:cli": "bun run --env-file=apps/cli/.env apps/cli/cli.ts",
    "build": "bun run --filter @app/web build",
    "build:cli": "bun run --env-file=apps/cli/.env --filter @app/cli build:release",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "test": "bun --env-file=apps/api/.env.example --env-file=apps/api/.env test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "nitro": "npm:nitro-nightly@latest"
  },
  "optionalDependencies": {
    "@faker-js/faker": "^10.4.0"
  }
}
